  "version": "1.0.0",
  "type": "module",
  "description": "GridFlow — a Smartsheet-inspired collaborative project grid with AI agent orchestration. Portfolio piece.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
